---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-slate-200 pt-16 pb-8 mt-auto">
  <div class="max-w-[960px] mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 lg:gap-12 mb-16">
      
      <div class="md:col-span-5 flex flex-col space-y-4">
        <a href="/blog" class="flex items-center gap-2 no-underline">
          <Logo size={24} />
          <span class="text-lg font-extrabold text-slate-800">Files<span class="text-blue-600">Ok</span> <span class="text-slate-400 font-medium">Blog</span></span>
        </a>
        <p class="text-sm text-slate-500 leading-relaxed max-w-sm">
          Deep dives into privacy-first web engineering, local file processing, and guides from the team building the fastest in-browser tools.
        </p>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-xs font-extrabold text-slate-800 uppercase tracking-widest mb-5">Explore</h4>
        <ul class="space-y-3 text-sm font-semibold text-slate-500 m-0 p-0 list-none">
          <li><a href="/blog" class="hover:text-blue-600 transition-colors no-underline">Latest Articles</a></li>
          <li><a href="/blog/engineering" class="hover:text-blue-600 transition-colors no-underline">Engineering</a></li>
          <li><a href="/blog/updates" class="hover:text-blue-600 transition-colors no-underline">Product Updates</a></li>
          <li><a href="/blog/guides" class="hover:text-blue-600 transition-colors no-underline">How-To Guides</a></li>
        </ul>
      </div>

      <div class="md:col-span-4 bg-slate-50 p-6 rounded-3xl border border-slate-100">
        <h4 class="text-xs font-extrabold text-slate-800 uppercase tracking-widest mb-3">The FilesOk App</h4>
        <p class="text-sm text-slate-500 mb-5 leading-relaxed">Need to compress or merge files right now? Do it instantly and securely inside your browser.</p>
        <a href="https://filesok.com" class="inline-flex items-center justify-center w-full bg-blue-600 text-white text-sm font-bold py-3 px-4 rounded-xl hover:bg-blue-700 transition-colors shadow-sm">
          Go to Main App
        </a>
      </div>

    </div>

    <div class="border-t border-slate-100 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest m-0">
        © {year} FilesOk. All rights reserved.
      </p>
      <div class="flex gap-5 text-xs font-semibold text-slate-500">
        <a href="https://filesok.com" class="hover:text-slate-800 transition-colors">Privacy Policy</a>
        <a href="https://filesok.com" class="hover:text-slate-800 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
