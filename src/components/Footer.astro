---
const year = new Date().getFullYear();
---
<footer style="border-top:4px solid #2563EB;background:#1E293B;padding:48px 24px 32px;margin-top:auto;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px;">

      <!-- Brand -->
      <div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
          <svg width="28" height="28" viewBox="0 0 512 512" fill="none" style="width:28px;height:28px;flex-shrink:0;">
            <defs>
              <linearGradient id="fbg2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#1E3A8A"/><stop offset="100%" stop-color="#2563EB"/></linearGradient>
              <linearGradient id="ffg2" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" stop-color="#FFFFFF"/><stop offset="100%" stop-color="#F8FAFC"/></linearGradient>
            </defs>
            <rect width="512" height="512" rx="116" fill="url(#fbg2)"/>
            <path d="M176 116C160 116 146 130 146 146L146 366C146 382 160 396 176 396L336 396C352 396 366 382 366 366L366 196L286 116Z" fill="url(#ffg2)"/>
            <path d="M286 116L286 176C286 187 295 196 306 196L366 196Z" fill="#E2E8F0"/>
            <rect x="196" y="236" width="60" height="14" rx="7" fill="#1E40AF"/>
            <rect x="196" y="276" width="120" height="14" rx="7" fill="#2563EB"/>
            <rect x="196" y="316" width="85" height="14" rx="7" fill="#93C5FD"/>
          </svg>
          <span style="font-size:18px;font-weight:800;color:#fff;font-family:'DM Sans',sans-serif;">Files<span style="color:#BFDBFE;">Ok</span></span>
        </div>
        <p style="font-size:12px;color:rgba(255,255,255,0.45);line-height:1.7;max-width:240px;margin:0;">Tips, guides, and insights on file compression and privacy — from the team building FilesOk.</p>
      </div>

      <!-- Image Tools -->
      <div>
        <div style="display:flex;align-items:center;gap:8px;font-size:12px;font-weight:800;color:#fff;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:18px;font-family:'DM Sans',sans-serif;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" style="width:16px;height:16px;flex-shrink:0;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Image Tools
        </div>
        <ul style="display:flex;flex-direction:column;gap:10px;list-style:none;padding:0;margin:0;">
          <li><a href="https://filesok.com/okimg/compress-image" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Compress Image</a></li>
          <li><a href="https://filesok.com/okimg/compress-to-kb" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Compress to KB</a></li>
          <li><a href="https://filesok.com/okimg/resize-image" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Resize Image</a></li>
          <li><a href="https://filesok.com/okimg/merge-images" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Merge Images</a></li>
        </ul>
      </div>

      <!-- PDF Tools -->
      <div>
        <div style="display:flex;align-items:center;gap:8px;font-size:12px;font-weight:800;color:#fff;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:18px;font-family:'DM Sans',sans-serif;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" style="width:16px;height:16px;flex-shrink:0;"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><path d="M14 2v6h6"/></svg>
          PDF Tools
        </div>
        <ul style="display:flex;flex-direction:column;gap:10px;list-style:none;padding:0;margin:0;">
          <li><a href="https://filesok.com/okpdf/jpg-to-pdf" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">JPG to PDF</a></li>
          <li><a href="https://filesok.com/okpdf/compress-pdf" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Compress PDF</a></li>
          <li><a href="https://filesok.com/okpdf/pdf-to-jpg" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">PDF to JPG</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <div style="display:flex;align-items:center;gap:8px;font-size:12px;font-weight:800;color:#fff;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:18px;font-family:'DM Sans',sans-serif;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" style="width:16px;height:16px;flex-shrink:0;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Resources
        </div>
        <ul style="display:flex;flex-direction:column;gap:10px;list-style:none;padding:0;margin:0;">
          <li><a href="https://filesok.com" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">FilesOk App</a></li>
          <li><a href="/blog" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;text-decoration:none;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Blog Home</a></li>
          <li><button onclick="document.getElementById('modal-privacy').style.display='flex'" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;background:none;border:none;cursor:pointer;padding:0;font-family:'DM Sans',sans-serif;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Privacy Policy</button></li>
          <li><button onclick="document.getElementById('modal-terms').style.display='flex'" style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:500;background:none;border:none;cursor:pointer;padding:0;font-family:'DM Sans',sans-serif;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Terms of Service</button></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Row -->
    <div style="border-top:1px solid rgba(255,255,255,0.08);padding-top:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <p style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.15em;margin:0;">© {year} FilesOk · Local Sandboxed Webtool</p>
      <div style="display:flex;gap:20px;">
        <button onclick="document.getElementById('modal-privacy').style.display='flex'" style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">Privacy Policy</button>
        <button onclick="document.getElementById('modal-terms').style.display='flex'" style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;" onmouseover="this.style.color='#93C5FD'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">Terms of Service</button>
      </div>
    </div>
  </div>
</footer>

<!-- PRIVACY MODAL -->
<div id="modal-privacy" style="display:none;position:fixed;inset:0;z-index:100;align-items:center;justify-content:center;padding:16px;background:rgba(30,41,59,0.8);backdrop-filter:blur(4px);">
  <div style="background:#fff;width:90%;max-width:600px;max-height:85vh;border-radius:32px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 25px 60px rgba(0,0,0,0.3);">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 28px;border-bottom:1px solid #F1F5F9;background:#F8FAFC;">
      <span style="font-size:17px;font-weight:800;color:#1E293B;font-family:'DM Sans',sans-serif;">Privacy Policy</span>
      <button onclick="document.getElementById('modal-privacy').style.display='none'" style="background:none;border:none;cursor:pointer;color:#64748B;font-size:24px;line-height:1;padding:4px;">×</button>
    </div>
    <div style="padding:28px;overflow-y:auto;font-family:'DM Sans',sans-serif;font-size:14px;color:#475569;line-height:1.7;">
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">1. Zero Data Collection</h3>
      <p style="margin:0 0 20px;">FilesOk operates on a strict "Local Processing" architecture. When you process an image or PDF, the file never leaves your device. All compression, resizing, and manipulation happens directly inside your browser's memory. We do not have servers that store your files.</p>
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">2. Analytics & Tracking</h3>
      <p style="margin:0 0 20px;">We use Vercel Web Analytics to track basic, anonymized page views. This data contains no personally identifiable information (PII) and no file contents.</p>
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">3. Newsletter Subscriptions</h3>
      <p style="margin:0 0 20px;">If you opt-in to our waitlist, your name and email are stored securely. We use this strictly for product updates and will never sell or share your contact information with third parties.</p>
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">4. Blog</h3>
      <p style="margin:0;">The FilesOk Blog does not use cookies or tracking scripts. Reading our articles is completely anonymous.</p>
    </div>
    <div style="padding:16px 28px;border-top:1px solid #F1F5F9;display:flex;justify-content:flex-end;">
      <button onclick="document.getElementById('modal-privacy').style.display='none'" style="background:#2563EB;color:#fff;font-weight:700;font-size:14px;padding:10px 24px;border-radius:12px;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;">Close</button>
    </div>
  </div>
</div>

<!-- TERMS MODAL -->
<div id="modal-terms" style="display:none;position:fixed;inset:0;z-index:100;align-items:center;justify-content:center;padding:16px;background:rgba(30,41,59,0.8);backdrop-filter:blur(4px);">
  <div style="background:#fff;width:90%;max-width:600px;max-height:85vh;border-radius:32px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 25px 60px rgba(0,0,0,0.3);">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 28px;border-bottom:1px solid #F1F5F9;background:#F8FAFC;">
      <span style="font-size:17px;font-weight:800;color:#1E293B;font-family:'DM Sans',sans-serif;">Terms of Service</span>
      <button onclick="document.getElementById('modal-terms').style.display='none'" style="background:none;border:none;cursor:pointer;color:#64748B;font-size:24px;line-height:1;padding:4px;">×</button>
    </div>
    <div style="padding:28px;overflow-y:auto;font-family:'DM Sans',sans-serif;font-size:14px;color:#475569;line-height:1.7;">
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">1. Acceptance of Terms</h3>
      <p style="margin:0 0 20px;">By accessing and using the FilesOk web application, you accept and agree to be bound by the terms and provisions of this agreement. Our tools are provided "as-is" without any warranties.</p>
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">2. Acceptable Use</h3>
      <p style="margin:0 0 20px;">Because all file processing happens locally on your device, you are entirely responsible for the files you process. You agree not to use the site to process or distribute unlawful material.</p>
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">3. Blog Content</h3>
      <p style="margin:0 0 20px;">The FilesOk Blog provides educational content on file compression, privacy, and related topics. Content is provided for informational purposes only and may not always reflect the latest changes to tools or platforms mentioned.</p>
      <h3 style="font-size:15px;font-weight:700;color:#1E293B;margin:0 0 8px;">4. Limitation of Liability</h3>
      <p style="margin:0;">FilesOk shall not be liable for any direct, indirect, incidental, or consequential damages resulting from the use or inability to use our tools, including loss of data during browser processing crashes.</p>
    </div>
    <div style="padding:16px 28px;border-top:1px solid #F1F5F9;display:flex;justify-content:flex-end;">
      <button onclick="document.getElementById('modal-terms').style.display='none'" style="background:#2563EB;color:#fff;font-weight:700;font-size:14px;padding:10px 24px;border-radius:12px;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;">Close</button>
    </div>
  </div>
</div>
