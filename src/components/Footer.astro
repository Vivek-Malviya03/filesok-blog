---
import Logo from './Logo.astro';
---

<footer class="border-t-[4px] border-blue-600 bg-slate-800 py-10 px-6 text-center md:text-left mt-auto">
  <div class="max-w-[1000px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-10 text-white/80">
    
    <div class="flex flex-col items-center md:items-start space-y-4">
      <div class="flex items-center gap-2">
        <Logo size={28} />
        <span class="text-lg font-extrabold text-white">Files<span class="text-blue-200">Ok</span></span>
      </div>
      <p class="text-xs text-white/55 leading-relaxed max-w-xs m-0">Secure and high-performance file utilities designed with a privacy-first approach.</p>
    </div>

    <div class="flex flex-col items-center md:items-start">
      <div class="text-sm md:text-base font-extrabold text-white tracking-[2px] mb-5 flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg> 
        Image Tools
      </div>
      <ul class="space-y-2 text-xs text-white/60 m-0 p-0 list-none">
        <li><a href="https://filesok.com/okimg/compress-image" class="hover:text-blue-300 transition-colors no-underline">Compress Image</a></li>
        <li><a href="https://filesok.com/okimg/compress-to-kb" class="hover:text-blue-300 transition-colors no-underline">Compress to KB</a></li>
        <li><a href="https://filesok.com/okimg/resize-image" class="hover:text-blue-300 transition-colors no-underline">Resize Image</a></li>
        <li><a href="https://filesok.com/okimg/merge-images" class="hover:text-blue-300 transition-colors no-underline">Merge Images</a></li>
      </ul>
    </div>

    <div class="flex flex-col items-center md:items-start">
      <div class="text-sm md:text-base font-extrabold text-white tracking-[2px] mb-5 flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg> 
        PDF Tools
      </div>
      <ul class="space-y-2 text-xs text-white/60 m-0 p-0 list-none">
        <li><a href="https://filesok.com/okpdf/jpg-to-pdf" class="hover:text-blue-300 transition-colors no-underline">JPG to PDF</a></li>
        <li><a href="https://filesok.com/okpdf/compress-pdf" class="hover:text-blue-300 transition-colors no-underline">Compress PDF</a></li>
        <li><a href="https://filesok.com/okpdf/pdf-to-jpg" class="hover:text-blue-300 transition-colors no-underline">PDF to JPG</a></li>
      </ul>
    </div>

  </div>
  
  <div class="max-w-[1200px] mx-auto border-t border-white/10 pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="text-[10px] md:text-[11px] text-white/40 font-bold uppercase tracking-[2px] m-0">© 2026 FilesOk · Local Sandboxed Webtool</p>
    <div class="flex gap-5 text-[10px] md:text-[11px] text-white/40 font-bold uppercase tracking-[1.5px]">
      <a href="https://filesok.com" class="hover:text-white transition-colors no-underline text-inherit">Privacy Policy</a>
      <a href="https://filesok.com" class="hover:text-white transition-colors no-underline text-inherit">Terms of Service</a>
    </div>
  </div>
</footer>
