---
import Logo from './Logo.astro';
---
<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <Logo size={36} />
      <span class="logo-text">Files<span class="logo-blue">Ok</span><span class="logo-suffix">/blog</span></span>
    </a>
    <div class="nav-right">
      <a href="https://filesok.com" class="nav-link">All Tools</a>
      <a href="https://filesok.com" class="nav-cta">Open App</a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    background: #fff;
    border-bottom: 4px solid #2563EB;
    position: sticky;
    top: 0;
    z-index: 40;
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .logo-text {
    font-size: 22px;
    font-weight: 800;
    color: #1E293B;
    letter-spacing: -0.5px;
  }
  .logo-blue { color: #2563EB; }
  .logo-suffix { color: #94A3B8; font-size: 16px; font-weight: 600; margin-left: 2px; }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-link {
    font-size: 14px;
    font-weight: 600;
    color: #64748B;
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover { color: #2563EB; }
  .nav-cta {
    font-size: 13px;
    font-weight: 700;
    padding: 9px 18px;
    border-radius: 10px;
    background: #2563EB;
    color: #fff;
    text-decoration: none;
    transition: background 0.15s;
  }
  .nav-cta:hover { background: #1D4ED8; }
  @media (max-width: 480px) {
    .logo-suffix { display: none; }
    .nav-link { display: none; }
  }
</style>
