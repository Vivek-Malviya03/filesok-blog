---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
  readingMins: number;
}
const { title, description, pubDate, slug, tags, readingMins } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const primaryTag = tags?.[0] ?? 'guide';
---
<a href={`/blog/${slug}`} class="group block bg-white border-2 border-slate-100 rounded-[28px] p-6 md:p-7 shadow-sm hover:shadow-lg hover:border-blue-200 transition-all duration-200 hover:-translate-y-1">
  <div class="flex items-center justify-between mb-4">
    <span class="inline-flex items-center bg-blue-50 text-blue-600 text-[10px] font-extrabold uppercase tracking-widest py-1.5 px-3 rounded-full border border-blue-100">.{primaryTag}</span>
    <span class="text-[11px] font-bold text-slate-400 font-mono">{readingMins} min &middot; {(readingMins * 0.6).toFixed(1)}KB</span>
  </div>
  <h2 class="text-xl font-extrabold text-slate-800 tracking-tight mb-2 leading-snug group-hover:text-blue-600 transition-colors">{title}</h2>
  <p class="text-sm text-slate-500 leading-relaxed mb-6 line-clamp-3">{description}</p>
  <div class="flex items-center justify-between pt-4 border-t border-slate-100">
    <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wide">{formattedDate}</span>
    <span class="text-sm font-bold text-blue-600 flex items-center gap-1 group-hover:gap-2 transition-all">
      Read article
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </span>
  </div>
</a>
