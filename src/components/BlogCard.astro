---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
  readingMins: number;
}
const { title, description, pubDate, slug, tags, readingMins } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const primaryTag = tags?.[0] ?? 'guide';
---
<a href={`https://filesok.com/blog/${slug}/`} class="blog-card">
  <div class="card-top">
    <span class="tag-chip">.{primaryTag}</span>
    <span class="size-chip">{readingMins} min · {(readingMins * 0.6).toFixed(1)}KB</span>
  </div>
  <h2 class="card-title">{title}</h2>
  <p class="card-desc">{description}</p>
  <div class="card-footer">
    <span class="card-date">{formattedDate}</span>
    <span class="card-read">Read article →</span>
  </div>
</a>
<style>
  .blog-card { display:block; background:#fff; border:2px solid #F1F5F9; border-radius:24px; padding:24px; text-decoration:none; transition:all 0.2s ease; box-shadow:0 1px 4px rgba(0,0,0,0.04); font-family:'DM Sans',sans-serif; }
  .blog-card:hover { border-color:#BFDBFE; box-shadow:0 8px 24px rgba(37,99,235,0.1); transform:translateY(-2px); }
  .card-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
  .tag-chip { font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.1em; color:#2563EB; background:#EFF6FF; border:1px solid #BFDBFE; padding:4px 10px; border-radius:999px; }
  .size-chip { font-size:11px; font-weight:700; color:#94A3B8; font-family:'DM Mono',monospace; }
  .card-title { font-size:18px; font-weight:800; color:#1E293B; letter-spacing:-0.3px; line-height:1.3; margin:0 0 8px; transition:color 0.15s; }
  .blog-card:hover .card-title { color:#2563EB; }
  .card-desc { font-size:14px; color:#64748B; line-height:1.6; margin:0 0 18px; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .card-footer { display:flex; align-items:center; justify-content:space-between; border-top:1px solid #F1F5F9; padding-top:14px; }
  .card-date { font-size:11px; font-weight:700; color:#94A3B8; text-transform:uppercase; letter-spacing:0.05em; }
  .card-read { font-size:13px; font-weight:700; color:#2563EB; }
  @media (max-width:480px) {
    .blog-card { padding:20px 18px; }
    .card-title { font-size:17px; }
    .card-desc { font-size:13px; }
  }
</style>
