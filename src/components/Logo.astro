---
interface Props { size?: number; }
const { size = 36 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1E3A8A" />
      <stop offset="100%" stop-color="#2563EB" />
    </linearGradient>
    <radialGradient id="nimbusCore" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#FFFFFF" stop-opacity="1" />
      <stop offset="25%" stop-color="#BFDBFE" stop-opacity="0.9" />
      <stop offset="55%" stop-color="#3B82F6" stop-opacity="0.4" />
      <stop offset="100%" stop-color="#2563EB" stop-opacity="0" />
    </radialGradient>
    <radialGradient id="nimbusAura" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#60A5FA" stop-opacity="0.5" />
      <stop offset="100%" stop-color="#1D4ED8" stop-opacity="0" />
    </radialGradient>
    <filter id="premiumShadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="24" stdDeviation="32" flood-color="#020617" flood-opacity="0.4" />
      <feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="#000000" flood-opacity="0.25" />
    </filter>
    <filter id="foldShadow">
      <feDropShadow dx="-4" dy="6" stdDeviation="6" flood-color="#000000" flood-opacity="0.15" />
    </filter>
    <linearGradient id="fileGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" />
      <stop offset="100%" stop-color="#F8FAFC" />
    </linearGradient>
    <linearGradient id="foldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" />
      <stop offset="100%" stop-color="#E2E8F0" />
    </linearGradient>
  </defs>
  <rect width="512" height="512" rx="116" fill="url(#bgGrad)" />
  <circle cx="256" cy="256" r="220" fill="url(#nimbusAura)" />
  <circle cx="256" cy="256" r="160" fill="url(#nimbusCore)" />
  <g stroke="#FFFFFF" stroke-linecap="round" opacity="0.15">
    <line x1="256" y1="46" x2="256" y2="466" stroke-width="2"/>
    <line x1="46" y1="256" x2="466" y2="256" stroke-width="2"/>
    <line x1="107" y1="107" x2="405" y2="405" stroke-width="1.5"/>
    <line x1="107" y1="405" x2="405" y2="107" stroke-width="1.5"/>
  </g>
  <g filter="url(#premiumShadow)">
    <path d="M 176 116 C 160 116 146 130 146 146 L 146 366 C 146 382 160 396 176 396 L 336 396 C 352 396 366 382 366 366 L 366 196 L 286 116 Z" fill="url(#fileGrad)" />
    <path d="M 286 116 L 286 176 C 286 187 295 196 306 196 L 366 196 Z" fill="url(#foldGrad)" filter="url(#foldShadow)"/>
    <rect x="196" y="236" width="60" height="14" rx="7" fill="#1E40AF" />
    <rect x="196" y="276" width="120" height="14" rx="7" fill="#2563EB" />
    <rect x="196" y="316" width="85" height="14" rx="7" fill="#93C5FD" />
  </g>
  <rect width="510" height="510" x="1" y="1" rx="115" fill="none" stroke="#FFFFFF" stroke-opacity="0.1" stroke-width="2" />
</svg>
