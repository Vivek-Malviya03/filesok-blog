---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title="FilesOk | Blog" description="Latest updates and guides from FilesOk" />
  </head>
  <body class="selection:bg-blue-100 flex flex-col min-h-screen bg-slate-50 m-0 p-0 font-sans text-slate-800">
    <Header />
    
    <main class="flex-grow w-full max-w-[960px] mx-auto px-4 md:px-6 py-12 md:py-20">
      
      <div class="text-center mb-12 md:mb-16 px-2">
        <h1 class="text-[clamp(36px,8vw,56px)] font-extrabold text-slate-800 leading-[1.1] tracking-tight mb-4">
          The FilesOk <span class="text-blue-600">Blog.</span>
        </h1>

        <p class="text-[clamp(15px,4vw,18px)] text-slate-500 max-w-[540px] mx-auto leading-relaxed">
          Updates, guides, and technical insights on secure, client-side file processing.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <BlogCard 
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id || post.slug} 
            tags={post.data.tags || ['guide']}
            readingMins={post.data.readingMins || 3}
          />
        ))}
      </div>
      
    </main>

    <Footer />
  </body>
</html>
