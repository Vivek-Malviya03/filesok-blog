---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  readingMins: number;
}

const { title, description, pubDate, author, readingMins } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | FilesOk Blog</title>
  <meta name="description" content={description} />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <Header />
  <main class="post-main">
    <article class="post-container">
      <header class="post-header">
        <div class="post-meta-line">
          <span class="meta-date">{formattedDate}</span>
          <span class="meta-dot">•</span>
          <span class="meta-author">{author}</span>
          <span class="meta-dot">•</span>
          <span class="meta-reading">{readingMins} min read</span>
        </div>
        <h1 class="post-headline">{title}</h1>
        <p class="post-subheading">{description}</p>
      </header>

      <div class="post-body">
        <slot />
      </div>

      <aside class="post-cta-section">
        <div class="cta-card">
          <h3 class="cta-title">Try FilesOk Now</h3>
          <p class="cta-text">No sign-ups, no tracking. All processing happens on your device.</p>
          <a href="https://filesok.com" class="cta-link">Open FilesOk →</a>
        </div>
      </aside>

      <footer class="post-footer">
        <a href="/" class="back-link">← Back to articles</a>
      </footer>
    </article>
  </main>
  <Footer />

  <style>
    .post-main {
      background: var(--white);
      padding: 60px 20px;
      min-height: 60vh;
    }
    .post-container {
      max-width: 700px;
      margin: 0 auto;
    }
    .post-header {
      margin-bottom: 50px;
      text-align: center;
    }
    .post-meta-line {
      font-size: 13px;
      font-weight: 600;
      color: var(--gray-mid);
      letter-spacing: 0.3px;
      margin-bottom: 20px;
      text-transform: uppercase;
    }
    .meta-dot {
      margin: 0 6px;
      opacity: 0.5;
    }
    .post-headline {
      font-size: clamp(36px, 8vw, 52px);
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1.15;
      color: var(--gray-dark);
      margin: 0 0 16px;
    }
    .post-subheading {
      font-size: 18px;
      font-weight: 500;
      color: var(--gray-mid);
      line-height: 1.7;
      margin: 0;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .post-body {
      font-size: 16px;
      line-height: 1.85;
      color: var(--gray-dark);
      margin-bottom: 60px;
      text-align: left;
    }

    .post-body :global(h2) {
      font-size: 32px;
      font-weight: 800;
      color: var(--gray-dark);
      margin: 50px 0 25px;
      letter-spacing: -0.5px;
    }

    .post-body :global(h3) {
      font-size: 24px;
      font-weight: 700;
      color: var(--gray-dark);
      margin: 40px 0 20px;
    }

    .post-body :global(p) {
      margin: 0 0 20px;
      line-height: 1.85;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
      margin: 0 0 20px 24px;
      padding: 0;
    }

    .post-body :global(li) {
      margin-bottom: 12px;
      line-height: 1.8;
    }

    .post-body :global(blockquote) {
      border-left: 4px solid var(--blue-main);
      padding: 0 0 0 24px;
      margin: 35px 0;
      font-style: italic;
      color: var(--gray-mid);
      font-size: 17px;
    }

    .post-body :global(code) {
      background: var(--gray-pale);
      color: var(--gray-dark);
      padding: 3px 8px;
      border-radius: 5px;
      font-family: 'DM Mono', monospace;
      font-size: 14px;
    }

    .post-body :global(pre) {
      background: var(--gray-pale);
      border: 1px solid var(--gray-border);
      border-radius: 12px;
      padding: 20px;
      overflow-x: auto;
      margin: 25px 0;
    }

    .post-body :global(pre code) {
      background: none;
      padding: 0;
      font-size: 13px;
    }

    .post-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 25px 0;
      font-size: 15px;
    }

    .post-body :global(th) {
      background: var(--gray-pale);
      border: 1px solid var(--gray-border);
      padding: 14px;
      text-align: left;
      font-weight: 700;
    }

    .post-body :global(td) {
      border: 1px solid var(--gray-border);
      padding: 14px;
    }

    .post-cta-section {
      background: linear-gradient(135deg, var(--blue-pale) 0%, #F0F9FF 100%);
      border: 2px solid var(--blue-border);
      border-radius: 20px;
      padding: 45px;
      margin-bottom: 50px;
      text-align: center;
    }

    .cta-card h3 {
      font-size: 26px;
      font-weight: 800;
      color: var(--gray-dark);
      margin: 0 0 12px;
    }

    .cta-card p {
      font-size: 16px;
      color: var(--gray-mid);
      margin: 0 0 24px;
      line-height: 1.6;
    }

    .cta-link {
      display: inline-block;
      background: var(--blue-main);
      color: white;
      font-weight: 700;
      font-size: 15px;
      padding: 14px 32px;
      border-radius: 12px;
      transition: all 0.2s ease;
      text-decoration: none;
    }

    .cta-link:hover {
      background: var(--blue-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(37, 99, 235, 0.15);
    }

    .post-footer {
      border-top: 1px solid var(--gray-border);
      padding-top: 40px;
    }

    .back-link {
      font-size: 15px;
      font-weight: 700;
      color: var(--blue-main);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .back-link:hover {
      color: var(--blue-dark);
    }

    @media (max-width: 640px) {
      .post-main { padding: 40px 16px; }
      .post-headline { font-size: 32px; }
      .post-body { font-size: 15px; }
      .post-cta-section { padding: 30px 20px; }
      .cta-card h3 { font-size: 22px; }
    }
  </style>
</body>
</html>
