---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  readingMins?: number;
  tags?: string[];
}

const { title, description, pubDate, author = 'FilesOk Team', readingMins = 5, tags = [] } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const primaryTag = tags?.[0] ?? 'guide';
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="google-site-verification" content="-ZdAQRIUvyyJa3OBmVwFtt7cdi3SNT7CTaDkQ5yWTbc" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title} | FilesOk Blog</title>
  <meta name="description" content={description}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:type" content="article"/>
  
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
</head>
<body>
  <Header/>
  <main class="post-main">
    <div class="post-wrap fade-up">

      <a href="/blog/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:16px;height:16px;flex-shrink:0;"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
        All Articles
      </a>

      <!-- HEADER CARD -->
      <div class="post-header-card">
        <div class="post-meta">
          <span class="post-tag">.{primaryTag}</span>
          <span class="post-date">{formattedDate}</span>
          <span class="dot">·</span>
          <span class="post-mins">{readingMins} min read</span>
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-desc">{description}</p>
        <div class="post-author">
          <div class="author-avatar">
            <svg width="16" height="16" viewBox="0 0 512 512" fill="none" style="width:16px;height:16px;"><path d="M176 116C160 116 146 130 146 146L146 366C146 382 160 396 176 396L336 396C352 396 366 382 366 366L366 196L286 116Z" fill="white" opacity="0.9"/></svg>
          </div>
          <div>
            <p class="author-name">{author}</p>
            <p class="author-sub">FilesOk Team</p>
          </div>
        </div>
      </div>

      <!-- CONTENT -->
      <div class="post-content-card post-body">
        <slot/>
      </div>

      <!-- CTA -->
      <div class="post-cta-card">
        <p class="cta-badge">Free · No sign-up · Private</p>
        <h3 class="cta-h3">Try FilesOk Now</h3>
        <p class="cta-p">No uploads, no tracking. All processing happens directly on your device.</p>
        <a href="https://filesok.com" class="cta-btn">
          Open FilesOk Free
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:14px;height:14px;flex-shrink:0;"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
       <div class="post-back">
        <a href="/blog/" class="back-link-bottom">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:16px;height:16px;flex-shrink:0;"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
          Back to all articles
        </a>
      </div>
    </div>
  </main>
  <Footer/>
</body>
</html>

<style>
  body { background:#F8FAFC; font-family:'DM Sans',sans-serif; margin:0; }
  .post-main { padding:32px 16px 60px; }
  .post-wrap { max-width:720px; margin:0 auto; }

  .back-link { display:inline-flex; align-items:center; gap:8px; font-size:14px; font-weight:700; color:#64748B; text-decoration:none; margin-bottom:20px; transition:color 0.15s; }
  .back-link:hover { color:#2563EB; }

  .post-header-card { background:#fff; border:2px solid #F1F5F9; border-radius:28px; padding:32px; margin-bottom:14px; box-shadow:0 1px 4px rgba(0,0,0,0.04); }
  .post-meta { display:flex; align-items:center; gap:8px; margin-bottom:16px; flex-wrap:wrap; }
  .post-tag { font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.1em; color:#2563EB; background:#EFF6FF; border:1px solid #BFDBFE; padding:4px 12px; border-radius:999px; }
  .post-date, .post-mins { font-size:12px; font-weight:700; color:#94A3B8; text-transform:uppercase; letter-spacing:0.05em; }
  .dot { color:#CBD5E1; }
  .post-title { font-size:clamp(24px,5vw,42px); font-weight:800; color:#1E293B; letter-spacing:-0.8px; line-height:1.15; margin:0 0 14px; }
  .post-desc { font-size:16px; color:#64748B; line-height:1.7; margin:0 0 20px; }
  .post-author { display:flex; align-items:center; gap:12px; border-top:1px solid #F1F5F9; padding-top:18px; }
  .author-avatar { width:34px; height:34px; background:#2563EB; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .author-name { font-size:14px; font-weight:700; color:#1E293B; margin:0; }
  .author-sub { font-size:11px; color:#94A3B8; font-weight:600; margin:2px 0 0; }

  .post-content-card { background:#fff; border:2px solid #F1F5F9; border-radius:28px; padding:32px; margin-bottom:14px; box-shadow:0 1px 4px rgba(0,0,0,0.04); }

  .post-cta-card { background:#1E293B; border-radius:28px; padding:36px 28px; text-align:center; margin-bottom:28px; }
  .cta-badge { font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:0.15em; color:#93C5FD; margin:0 0 12px; }
  .cta-h3 { font-size:clamp(20px,4vw,26px); font-weight:800; color:#fff; margin:0 0 10px; letter-spacing:-0.5px; }
  .cta-p { font-size:14px; color:#94A3B8; line-height:1.6; margin:0 auto 22px; max-width:360px; }
  .cta-btn { display:inline-flex; align-items:center; gap:8px; background:#2563EB; color:#fff; font-weight:700; font-size:14px; padding:12px 26px; border-radius:14px; text-decoration:none; transition:background 0.2s; }
  .cta-btn:hover { background:#1D4ED8; }

  .post-back { border-top:2px solid #E2E8F0; padding-top:20px; }
  .back-link-bottom { display:inline-flex; align-items:center; gap:8px; font-size:14px; font-weight:700; color:#2563EB; text-decoration:none; }
  .back-link-bottom:hover { color:#1D4ED8; }

  /* MOBILE */
  @media (max-width:640px) {
    .post-main { padding:20px 12px 48px; }
    .post-header-card { padding:22px 18px; border-radius:20px; }
    .post-content-card { padding:22px 18px; border-radius:20px; }
    .post-cta-card { padding:28px 18px; border-radius:20px; }
    .post-title { font-size:24px; }
    .post-desc { font-size:15px; }
    .cta-btn { width:100%; justify-content:center; }
    .post-meta { gap:6px; }
    .post-date, .post-mins { font-size:11px; }
  }
</style>

<style is:global>
  .post-body { font-size:16px; line-height:1.85; color:#334155; font-family:'DM Sans',sans-serif; }
  .post-body h2 { font-size:clamp(20px,4vw,26px); font-weight:800; color:#1E293B; margin:40px 0 16px; letter-spacing:-0.5px; padding-bottom:10px; border-bottom:2px solid #F1F5F9; }
  .post-body h3 { font-size:clamp(17px,3vw,21px); font-weight:700; color:#1E293B; margin:32px 0 12px; }
  .post-body p { margin:0 0 16px; }
  .post-body ul, .post-body ol { margin:0 0 16px 22px; padding:0; }
  .post-body li { margin-bottom:10px; line-height:1.8; }
  .post-body strong { font-weight:700; color:#1E293B; }
  .post-body blockquote { border-left:4px solid #2563EB; padding:0 0 0 18px; margin:24px 0; color:#64748B; font-style:italic; }
  .post-body code { background:#F8FAFC; border:1px solid #E2E8F0; padding:2px 7px; border-radius:5px; font-family:'DM Mono',monospace; font-size:13px; color:#2563EB; word-break:break-word; }
  .post-body pre { background:#1E293B; color:#E2E8F0; padding:18px; border-radius:14px; overflow-x:auto; margin:18px 0; }
  .post-body pre code { background:none; border:none; color:inherit; padding:0; }
  .post-body table { width:100%; border-collapse:collapse; margin:18px 0; font-size:13px; display:block; overflow-x:auto; }
  .post-body th { background:#F8FAFC; border:1px solid #E2E8F0; padding:10px 12px; font-weight:700; color:#1E293B; text-align:left; white-space:nowrap; }
  .post-body td { border:1px solid #E2E8F0; padding:10px 12px; }
  .post-body tr:nth-child(even) td { background:#F8FAFC; }
  .post-body a { color:#2563EB; font-weight:600; }
  .post-body hr { border:none; border-top:2px solid #F1F5F9; margin:32px 0; }
  .post-body img { max-width:100%; height:auto; border-radius:12px; }
  @media (max-width:640px) {
    .post-body { font-size:15px; }
    .post-body h2 { font-size:20px; }
    .post-body h3 { font-size:17px; }
    .post-body pre { padding:14px; font-size:13px; }
  }
</style>
