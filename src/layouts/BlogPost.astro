---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="selection:bg-blue-100 flex flex-col min-h-screen bg-slate-50 m-0 p-0 font-sans text-slate-800">
    <Header />
    
    <main class="flex-grow w-full max-w-[800px] mx-auto px-4 md:px-6 py-12 md:py-16">
      <article class="bg-white border-2 border-slate-100 rounded-[32px] p-6 md:p-12 shadow-sm">
        
        {heroImage && (
          <div class="w-full aspect-[21/9] rounded-2xl overflow-hidden mb-10 bg-slate-100">
            <img src={heroImage} alt={title} class="w-full h-full object-cover" />
          </div>
        )}
        
        <div class="text-center mb-10 border-b border-slate-100 pb-8">
          <div class="text-[11px] font-bold text-blue-600 uppercase tracking-widest mb-4">
            <FormattedDate date={pubDate} />
          </div>
          <h1 class="text-[clamp(28px,5vw,42px)] font-extrabold text-slate-800 leading-tight tracking-tight mb-4">
            {title}
          </h1>
        </div>

        <div class="text-slate-600 leading-relaxed text-base md:text-lg">
          <slot />
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
