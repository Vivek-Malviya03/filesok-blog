---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  readingMins: number;
  tags: string[];
}

const { title, description, pubDate, author = 'FilesOk Team', readingMins = 5, tags = [] } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const primaryTag = tags?.[0] ?? 'guide';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | FilesOk Blog</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
  <Header />

  <main class="post-main">

    <div class="post-wrap fade-up">

      <!-- BACK -->
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
        All Articles
      </a>

      <!-- HEADER CARD -->
      <div class="post-header-card">
        <div class="post-meta">
          <span class="post-tag">.{primaryTag}</span>
          <span class="post-date">{formattedDate}</span>
          <span class="dot">·</span>
          <span class="post-mins">{readingMins} min read</span>
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-desc">{description}</p>
        <div class="post-author">
          <div class="author-avatar">
            <svg width="18" height="18" viewBox="0 0 512 512" fill="none"><path d="M 176 116 C 160 116 146 130 146 146 L 146 366 C 146 382 160 396 176 396 L 336 396 C 352 396 366 382 366 366 L 366 196 L 286 116 Z" fill="white" opacity="0.9"/></svg>
          </div>
          <div>
            <p class="author-name">{author}</p>
            <p class="author-label">FilesOk Team</p>
          </div>
        </div>
      </div>

      <!-- CONTENT CARD -->
      <div class="post-content-card prose-content">
        <slot />
      </div>

      <!-- CTA CARD -->
      <div class="post-cta-card">
        <p class="cta-badge">Free · No sign-up · Private</p>
        <h3 class="cta-h3">Try FilesOk Now</h3>
        <p class="cta-p">No uploads, no tracking. All processing happens directly on your device.</p>
        <a href="https://filesok.com" class="cta-btn">
          Open FilesOk Free
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- BOTTOM BACK -->
      <div class="post-bottom">
        <a href="/" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
          Back to all articles
        </a>
      </div>

    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  body { background: #F8FAFC; }

  .post-main { padding: 40px 24px 60px; }
  .post-wrap { max-width: 720px; margin: 0 auto; }

  .back-link { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 700; color: #64748B; text-decoration: none; margin-bottom: 24px; transition: color 0.15s; }
  .back-link:hover { color: #2563EB; }

  .post-header-card { background: #fff; border: 2px solid #F1F5F9; border-radius: 32px; padding: 40px 48px; margin-bottom: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
  .post-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
  .post-tag { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #2563EB; background: #EFF6FF; border: 1px solid #BFDBFE; padding: 4px 12px; border-radius: 999px; }
  .post-date, .post-mins { font-size: 12px; font-weight: 700; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.05em; }
  .dot { color: #CBD5E1; font-size: 14px; }
  .post-title { font-size: clamp(28px, 5vw, 44px); font-weight: 800; color: #1E293B; letter-spacing: -0.8px; line-height: 1.15; margin: 0 0 16px; }
  .post-desc { font-size: 17px; color: #64748B; line-height: 1.7; margin: 0 0 24px; }
  .post-author { display: flex; align-items: center; gap: 12px; border-top: 1px solid #F1F5F9; padding-top: 20px; }
  .author-avatar { width: 36px; height: 36px; background: #2563EB; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .author-name { font-size: 14px; font-weight: 700; color: #1E293B; margin: 0; }
  .author-label { font-size: 11px; color: #94A3B8; font-weight: 600; margin: 2px 0 0; }

  .post-content-card { background: #fff; border: 2px solid #F1F5F9; border-radius: 32px; padding: 40px 48px; margin-bottom: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }

  .post-cta-card { background: #1E293B; border-radius: 32px; padding: 40px; text-align: center; margin-bottom: 32px; }
  .cta-badge { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #93C5FD; margin: 0 0 14px; }
  .cta-h3 { font-size: 26px; font-weight: 800; color: #fff; margin: 0 0 10px; letter-spacing: -0.5px; }
  .cta-p { font-size: 15px; color: #94A3B8; line-height: 1.6; margin: 0 0 24px; max-width: 380px; margin-left: auto; margin-right: auto; }
  .cta-btn { display: inline-flex; align-items: center; gap: 8px; background: #2563EB; color: #fff; font-weight: 700; font-size: 14px; padding: 13px 28px; border-radius: 14px; text-decoration: none; transition: background 0.2s; }
  .cta-btn:hover { background: #1D4ED8; }

  .post-bottom { border-top: 2px solid #E2E8F0; padding-top: 24px; }

  @media (max-width: 640px) {
    .post-header-card, .post-content-card { padding: 24px 20px; }
    .post-cta-card { padding: 28px 20px; }
  }
</style>

<style is:global>
  .prose-content { font-size: 16px; line-height: 1.85; color: #334155; }
  .prose-content h2 { font-size: 26px; font-weight: 800; color: #1E293B; margin: 44px 0 18px; letter-spacing: -0.5px; padding-bottom: 12px; border-bottom: 2px solid #F1F5F9; }
  .prose-content h3 { font-size: 21px; font-weight: 700; color: #1E293B; margin: 36px 0 14px; }
  .prose-content p { margin: 0 0 18px; }
  .prose-content ul, .prose-content ol { margin: 0 0 18px 24px; padding: 0; }
  .prose-content li { margin-bottom: 10px; line-height: 1.8; }
  .prose-content strong { font-weight: 700; color: #1E293B; }
  .prose-content blockquote { border-left: 4px solid #2563EB; padding: 0 0 0 20px; margin: 28px 0; color: #64748B; font-style: italic; }
  .prose-content code { background: #F8FAFC; border: 1px solid #E2E8F0; padding: 2px 7px; border-radius: 5px; font-family: 'DM Mono', monospace; font-size: 13px; color: #2563EB; }
  .prose-content pre { background: #1E293B; color: #E2E8F0; padding: 20px; border-radius: 16px; overflow-x: auto; margin: 20px 0; }
  .prose-content pre code { background: none; border: none; color: inherit; padding: 0; }
  .prose-content table { width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 14px; }
  .prose-content th { background: #F8FAFC; border: 1px solid #E2E8F0; padding: 12px 14px; font-weight: 700; color: #1E293B; text-align: left; }
  .prose-content td { border: 1px solid #E2E8F0; padding: 12px 14px; }
  .prose-content tr:nth-child(even) td { background: #F8FAFC; }
  .prose-content a { color: #2563EB; font-weight: 600; }
  .prose-content hr { border: none; border-top: 2px solid #F1F5F9; margin: 36px 0; }
</style>
