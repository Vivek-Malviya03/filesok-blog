---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  readingMins?: number;
  tags?: string[];
}

const { title, description, pubDate, author = 'FilesOk Team', readingMins = 5, tags = [] } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const primaryTag = tags?.[0] ?? 'guide';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title} | FilesOk Blog</title>
  <meta name="description" content={description}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:type" content="article"/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
</head>
<body>
  <Header/>
  <main style="max-width:960px;margin:0 auto;padding:40px 24px 60px;">
    <div style="max-width:720px;margin:0 auto;" class="fade-up">

      <!-- BACK -->
      <a href="/blog" style="display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:700;color:#64748B;margin-bottom:24px;transition:color 0.15s;" onmouseover="this.style.color='#2563EB'" onmouseout="this.style.color='#64748B'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:16px;height:16px;"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
        All Articles
      </a>

      <!-- HEADER CARD -->
      <div style="background:#fff;border:2px solid #F1F5F9;border-radius:32px;padding:40px 48px;margin-bottom:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04);">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
          <span style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#2563EB;background:#EFF6FF;border:1px solid #BFDBFE;padding:4px 12px;border-radius:999px;">.{primaryTag}</span>
          <span style="font-size:12px;font-weight:700;color:#94A3B8;text-transform:uppercase;letter-spacing:0.05em;">{formattedDate}</span>
          <span style="color:#CBD5E1;">·</span>
          <span style="font-size:12px;font-weight:700;color:#94A3B8;">{readingMins} min read</span>
        </div>
        <h1 style="font-size:clamp(28px,5vw,44px);font-weight:800;color:#1E293B;letter-spacing:-0.8px;line-height:1.15;margin:0 0 16px;">{title}</h1>
        <p style="font-size:17px;color:#64748B;line-height:1.7;margin:0 0 24px;">{description}</p>
        <div style="display:flex;align-items:center;gap:12px;border-top:1px solid #F1F5F9;padding-top:20px;">
          <div style="width:36px;height:36px;background:#2563EB;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 512 512" fill="none" style="width:18px;height:18px;"><path d="M176 116C160 116 146 130 146 146L146 366C146 382 160 396 176 396L336 396C352 396 366 382 366 366L366 196L286 116Z" fill="white" opacity="0.9"/></svg>
          </div>
          <div>
            <p style="font-size:14px;font-weight:700;color:#1E293B;margin:0;">{author}</p>
            <p style="font-size:11px;color:#94A3B8;font-weight:600;margin:2px 0 0;">FilesOk Team</p>
          </div>
        </div>
      </div>

      <!-- CONTENT CARD -->
      <div class="post-body" style="background:#fff;border:2px solid #F1F5F9;border-radius:32px;padding:40px 48px;margin-bottom:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04);">
        <slot/>
      </div>

      <!-- CTA CARD -->
      <div style="background:#1E293B;border-radius:32px;padding:40px;text-align:center;margin-bottom:32px;">
        <p style="font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.15em;color:#93C5FD;margin:0 0 14px;">Free · No sign-up · Private</p>
        <h3 style="font-size:26px;font-weight:800;color:#fff;margin:0 0 10px;letter-spacing:-0.5px;">Try FilesOk Now</h3>
        <p style="font-size:15px;color:#94A3B8;line-height:1.6;margin:0 auto 24px;max-width:380px;">No uploads, no tracking. All processing happens directly on your device.</p>
        <a href="https://filesok.com" style="display:inline-flex;align-items:center;gap:8px;background:#2563EB;color:#fff;font-weight:700;font-size:14px;padding:13px 28px;border-radius:14px;text-decoration:none;" onmouseover="this.style.background='#1D4ED8'" onmouseout="this.style.background='#2563EB'">
          Open FilesOk Free
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:14px;height:14px;"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- BOTTOM BACK -->
      <div style="border-top:2px solid #E2E8F0;padding-top:24px;">
        <a href="/blog" style="display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:700;color:#2563EB;" onmouseover="this.style.color='#1D4ED8'" onmouseout="this.style.color='#2563EB'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="width:16px;height:16px;"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
          Back to all articles
        </a>
      </div>

    </div>
  </main>
  <Footer/>
</body>
</html>

<style is:global>
  .post-body { font-size:16px; line-height:1.85; color:#334155; font-family:'DM Sans',sans-serif; }
  .post-body h2 { font-size:26px; font-weight:800; color:#1E293B; margin:44px 0 18px; letter-spacing:-0.5px; padding-bottom:12px; border-bottom:2px solid #F1F5F9; }
  .post-body h3 { font-size:21px; font-weight:700; color:#1E293B; margin:36px 0 14px; }
  .post-body p { margin:0 0 18px; }
  .post-body ul, .post-body ol { margin:0 0 18px 24px; padding:0; }
  .post-body li { margin-bottom:10px; line-height:1.8; }
  .post-body strong { font-weight:700; color:#1E293B; }
  .post-body blockquote { border-left:4px solid #2563EB; padding:0 0 0 20px; margin:28px 0; color:#64748B; font-style:italic; }
  .post-body code { background:#F8FAFC; border:1px solid #E2E8F0; padding:2px 7px; border-radius:5px; font-family:'DM Mono',monospace; font-size:13px; color:#2563EB; }
  .post-body pre { background:#1E293B; color:#E2E8F0; padding:20px; border-radius:16px; overflow-x:auto; margin:20px 0; }
  .post-body pre code { background:none; border:none; color:inherit; padding:0; }
  .post-body table { width:100%; border-collapse:collapse; margin:20px 0; font-size:14px; }
  .post-body th { background:#F8FAFC; border:1px solid #E2E8F0; padding:12px 14px; font-weight:700; color:#1E293B; text-align:left; }
  .post-body td { border:1px solid #E2E8F0; padding:12px 14px; }
  .post-body tr:nth-child(even) td { background:#F8FAFC; }
  .post-body a { color:#2563EB; font-weight:600; }
  .post-body hr { border:none; border-top:2px solid #F1F5F9; margin:36px 0; }
  @media (max-width:640px) {
    .post-body { padding:24px 20px !important; }
  }
</style>
